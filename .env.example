# Chain Selectors for CCIP
ARBITRUM_SEPOLIA_CHAIN_SELECTOR=3478487238524512106
BASE_SEPOLIA_CHAIN_SELECTOR=10344971235874465080

# Chainlink Price Feed Addresses (Arbitrum Sepolia)
