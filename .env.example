# =============================================================================
# APOLLOS FINANCE - Smart Contract Environment Variables
# Network: Arbitrum Sepolia (L2 Testnet)
# =============================================================================

# ======================== DEPLOYER CONFIGURATION ============================
# Private key for contract deployment (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Deployer address (for verification)
DEPLOYER_ADDRESS=0xYourDeployerAddress

# ======================== NETWORK RPC URLS ==================================
# Arbitrum Sepolia (Primary deployment network)
# Used by DeployAll and DeploySourceChain auto-authorization step
RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Base Sepolia (For CCIP cross-chain testing)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optimism Sepolia (For CCIP cross-chain testing)
OPTIMISM_SEPOLIA_RPC_URL=https://sepolia.optimism.io

# Ethereum Sepolia (For testing)
ETHEREUM_SEPOLIA_RPC_URL=https://rpc.sepolia.org

# ======================== BLOCK EXPLORER API KEYS ===========================
# Arbiscan API Key (untuk contract verification)
ARBISCAN_API_KEY=your_arbiscan_api_key

# Etherscan API Key (optional, untuk testnet verification)
ETHERSCAN_API_KEY=your_etherscan_api_key

# ======================== CHAINLINK CONFIGURATION ===========================
# Chainlink CCIP Router (Arbitrum Sepolia)
CCIP_ROUTER_ARBITRUM_SEPOLIA=0x2a9C5afB0d0e4BAb2BCdaE109EC4b0c4Be15a165

# Chainlink CCIP Router (Base Sepolia) 
CCIP_ROUTER_BASE_SEPOLIA=0xD3b06cEbF099CE7DA4AcCf578aaebFDBd6e88a93

# Existing ApollosCCIPReceiver deployed on Arbitrum Sepolia.
# Used by DeploySourceChain for auto setDestinationReceiver + auto authorization.
